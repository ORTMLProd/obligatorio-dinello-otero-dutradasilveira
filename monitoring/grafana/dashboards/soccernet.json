{
  "uid": "soccernet-monitoring",
  "title": "SoccerNet · Monitoreo de inferencia",
  "tags": ["soccernet", "ml"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Predicciones servidas (total)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(soccernet_predictions_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests / s por endpoint",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (endpoint) (rate(soccernet_requests_total[1m]))", "legendFormat": "{{endpoint}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latencia de inferencia (p50 / p95)",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum(rate(soccernet_prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(soccernet_prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Distribución de clases predichas (vivo)",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (predicted_label) (soccernet_predictions_total)", "legendFormat": "{{predicted_label}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Baseline de entrenamiento (referencia de drift)",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "soccernet_training_class_ratio", "legendFormat": "{{class_name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Proporción predicha por clase (drift en el tiempo)",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (predicted_label) (soccernet_predictions_total) / ignoring(predicted_label) group_left() sum(soccernet_predictions_total)", "legendFormat": "{{predicted_label}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
