# Por default EB solo abre el puerto 80 en el security group de la instancia.
# MLflow (5500) y Grafana (9090/3000) del stack completo necesitan acceso
# externo para poder verse desde afuera durante la demo/entrega.
# AWSEBSecurityGroup es el nombre lógico que EB le da al SG que crea para
# entornos "single instance" de la plataforma Docker.
Resources:
  MLflowIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: { "Fn::GetAtt": [AWSEBSecurityGroup, GroupId] }
      IpProtocol: tcp
      FromPort: 5500
      ToPort: 5500
      CidrIp: 0.0.0.0/0
  GrafanaIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: { "Fn::GetAtt": [AWSEBSecurityGroup, GroupId] }
      IpProtocol: tcp
      FromPort: 3000
      ToPort: 3000
      CidrIp: 0.0.0.0/0
